FROM ruby:3.2

WORKDIR /app

# Install required packages
RUN apt-get update -qq && apt-get install -y nodejs sqlite3 libsqlite3-dev

# Install bundler
RUN gem install bundler

# Copy Gemfiles
COPY Gemfile Gemfile.lock ./

# Install gems
RUN bundle install

# Copy full app
COPY . .

# Just test build
RUN echo "Build successful"