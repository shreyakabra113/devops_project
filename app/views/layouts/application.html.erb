<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
  .hero-bg {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }
  .btn-gradient {
    background: linear-gradient(45deg, #ff6b6b, #ffa500);
    border: none;
    color: white;
  }
  .btn-gradient:hover {
    background: linear-gradient(45deg, #ff5252, #ff8c00);
    color: white;
  }
  .feature-card {
    transition: transform 0.3s ease;
  }
  .feature-card:hover {
    transform: translateY(-10px);
  }
</style>

<% if controller_name == "chatbot" %>
  <%= yield %>
<% else %>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
  <a class="navbar-brand" href="/">⚖️ LegalApp</a>

  <div class="collapse navbar-collapse">
    <ul class="navbar-nav ms-auto">
      <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
      <li class="nav-item"><a class="nav-link" href="/cases">Cases</a></li>
      <li class="nav-item"><a class="nav-link" href="/chatbot">Chatbot</a></li>
    </ul>
  </div>
</nav>

<%= yield %>

<% end %>

<section class="hero-bg py-5">
  <div class="container text-center">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1 class="display-4 fw-bold mb-4">Revolutionize Your Legal Practice</h1>
        <p class="lead mb-4">
          Streamline case management, harness AI-powered insights, and deliver exceptional client service with our cutting-edge legal platform.
        </p>
        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
          <a href="#" class="btn btn-gradient btn-lg px-5 py-3 fw-bold">Start Managing Cases</a>
          <a href="#" class="btn btn-outline-light btn-lg px-5 py-3 fw-bold">Try Chatbot</a>
        </div>
      </div>
      <div class="col-lg-6 mt-4 mt-lg-0">
        <img src="https://images.unsplash.com/photo-1589829545856-d10d557cf95f?auto=format&fit=crop&w=800&q=80" class="img-fluid rounded shadow-lg" alt="Modern legal workspace">
      </div>
    </div>
  </div>
</section>

<section class="py-5 bg-light">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="display-6 fw-bold">Powerful Features for Modern Law Firms</h2>
      <p class="lead text-muted">Everything you need to manage cases efficiently and stay ahead in the legal landscape.</p>
    </div>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow feature-card">
          <div class="card-body text-center">
            <i class="bi bi-folder-fill text-primary fs-1 mb-3"></i>
            <h5 class="card-title fw-bold">Intelligent Case Management</h5>
            <p class="card-text">Organize documents, track deadlines, and manage filings with AI-assisted workflows.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow feature-card">
          <div class="card-body text-center">
            <i class="bi bi-search text-success fs-1 mb-3"></i>
            <h5 class="card-title fw-bold">Advanced Smart Search</h5>
            <p class="card-text">Instantly find cases, clients, and precedents with our powerful search engine.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow feature-card">
          <div class="card-body text-center">
            <i class="bi bi-robot text-warning fs-1 mb-3"></i>
            <h5 class="card-title fw-bold">AI-Powered Chatbot</h5>
            <p class="card-text">Get instant legal guidance, draft suggestions, and answers to complex questions.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-5 bg-primary text-white">
  <div class="container text-center">
    <h2 class="display-6 fw-bold mb-4">Ready to Transform Your Practice?</h2>
    <p class="lead mb-4">Join thousands of legal professionals who trust LegalApp for their daily operations.</p>
    <a href="#" class="btn btn-gradient btn-lg px-5 py-3 fw-bold">Get Started Today</a>
  </div>
</section>

<footer class="py-4 bg-dark text-white">
  <div class="container text-center">
    <small>© <%= Time.current.year %> LegalApp. All rights reserved. | <a href="#" class="text-white">Privacy Policy</a> | <a href="#" class="text-white">Terms of Service</a></small>
  </div>
</footer>

<!-- Bootstrap JS bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-Ttx9g31viTEqH7uTeVqTjzTfgcS6xMUY5qNA+xduzvzzn4asI3w2+WvHK6zJ+V2eI" crossorigin="anonymous"></script>
