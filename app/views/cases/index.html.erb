<p style="color: green"><%= notice %></p>

<% content_for :title, "Cases" %>

<h1>Cases</h1>

<div id="cases">
  <% @cases.each do |c| %>
    <%= render partial: "case", locals: { case_record: c } %>
    <p>
      <%= link_to "Show this case", c %>
    </p>
  <% end %>
</div>

<%= link_to "New case", new_case_path %>